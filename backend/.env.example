# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=mathmentor
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Session cookies
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_NAME=mathmentor_session

# ─────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ─────────────────────────────────────────────────────────────
# RECOMMENDED for Railway (outbound SMTP is blocked):
#   Set SENDGRID_API_KEY — the backend will automatically use SendGrid.
#   EMAIL_FROM_ADDRESS must be a verified sender in your SendGrid account.
#
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_TIMEOUT=10   # seconds before email send is abandoned (optional)
#
# FALLBACK — plain SMTP (works in local dev / other hosts):
#   Leave SENDGRID_API_KEY unset and configure the variables below.
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=you@example.com
#   EMAIL_HOST_PASSWORD=your-app-password
#   EMAIL_FROM_ADDRESS=noreply@yourdomain.com
#
# LOCAL DEV (no real emails sent — printed to console instead):
#   Leave SENDGRID_API_KEY unset and EMAIL_BACKEND at its default.
# ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@mathmentor.com
EMAIL_TIMEOUT=10

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Jitsi / JaaS
JAAS_APP_ID=your-jaas-app-id
JAAS_PRIVATE_KEY=your-jaas-private-key
JAAS_KEY_ID=your-jaas-key-id
